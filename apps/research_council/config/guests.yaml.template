# Copy of production guests.yaml — used by `./council.sh init` when config is missing.
# NVIDIA NIM RPM: 大模型 ~40/min，小模型(nano-30b) ~60/min — 当前 4–5 人并行够用
max_parallel: 6

guests:
  qwen:
    guest_type: llm
    model_tier: anchor
    role_id: macro_strategist
    role: "Global Macro Strategist — 跨资产宏观与情景概率"
    model: "gpu-llama/qwen3.6-35b"
    command: "opencode run -m gpu-llama/qwen3.6-35b --auto"
    enabled: true
    timeout_seconds: 180
    allow_parallel: false

  north:
    guest_type: llm
    model_tier: floor
    role_id: energy_analyst
    role: "Commodities Desk Head — 黄金、原油、能源"
    model: "openrouter/cohere/north-mini-code:free"
    command: "opencode run -m openrouter/cohere/north-mini-code:free --auto"
    enabled: true
    timeout_seconds: 180
    allow_parallel: true

  nemo:
    guest_type: llm
    model_tier: floor
    role_id: rates_fx_strategist
    role: "Rates & FX Strategist — 美债、美元、人民币、资金流"
    model: "nvidia/nvidia/nemotron-3-nano-30b-a3b"
    command: "opencode run -m nvidia/nvidia/nemotron-3-nano-30b-a3b --auto"
    enabled: true
    timeout_seconds: 90
    allow_parallel: true

  mimo:
    guest_type: llm
    model_tier: floor
    role_id: equity_strategist
    role: "Equity Strategist — 个股定价、财报、板块β与行业轮动"
    model: "opencode/deepseek-v4-flash-free"
    command: "opencode run -m opencode/deepseek-v4-flash-free --auto"
    enabled: true
    timeout_seconds: 120
    allow_parallel: true

  codex:
    guest_type: llm
    model_tier: local
    role_id: logic_auditor
    role: "Codex Local — 推理链审计与可证伪性检验（无头 exec）"
    model: "codex/gpt-5.6-sol"
    command: "bash scripts/run_codex_guest.sh"
    enabled: true
    timeout_seconds: 180
    allow_parallel: true

  qoder:
    guest_type: llm
    model_tier: local
    role_id: synthesis_reviewer
    role: "Qoder CLI Local — 综合推理与跨模型对照（无头 -p）"
    model: "qoder/default"
    command: "bash scripts/run_qoder_guest.sh"
    enabled: true
    # Aligned with config/guests.yaml — Qoder CLI runs can exceed 180s.
    timeout_seconds: 360
    allow_parallel: true

  laguna:
    guest_type: llm
    model_tier: premium
    role_id: geopolitics_analyst
    role: "Grok 4.3 — 地缘与政策风险（共享 context 优先，简洁增量）"
    model: "hermes-grok/grok-4.3"
    command: "opencode run -m hermes-grok/grok-4.3 --auto"
    enabled: true
    timeout_seconds: 120
    allow_parallel: true

  tsla_feed:
    guest_type: script
    model_tier: script
    role_id: equity_data_feed
    role: "Equity Data Feed — TSLA 行情脚本（证据层）"
    script_symbol: TSLA
    command: "python3 scripts/fetch_equity.py TSLA"
    enabled: true
    timeout_seconds: 30
    allow_parallel: true

  context_collector:
    guest_type: llm
    model_tier: floor
    role: "Context Collector — 脚本数据之上的轻量背景整理（不联网）"
    model: "nvidia/nvidia/nemotron-3-nano-30b-a3b"
    command: "opencode run -m nvidia/nvidia/nemotron-3-nano-30b-a3b --auto"
    enabled: true
    timeout_seconds: 60
    allow_parallel: true

  summarizer:
    guest_type: llm
    model_tier: floor
    role: "Meeting Secretary"
    model: "nvidia/nvidia/nemotron-3-nano-30b-a3b"
    command: "opencode run -m nvidia/nvidia/nemotron-3-nano-30b-a3b --auto"
    enabled: true
    timeout_seconds: 120
    allow_parallel: true