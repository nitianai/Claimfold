{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claimfold.local/schemas/meeting_plan.schema.json",
  "title": "Claimfold Meeting Plan",
  "description": "Frozen compile artifact for Scenario/Role/Executor bindings (PR1 contract).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meeting_id",
    "topic",
    "scenario",
    "participants",
    "stages",
    "decision_policy",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["1.0"]
    },
    "meeting_id": {
      "type": "string",
      "minLength": 1
    },
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "scenario": { "$ref": "#/$defs/scenario_ref" },
    "participants": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/participant" }
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/stage" }
    },
    "decision_policy": {
      "type": "object",
      "additionalProperties": true
    },
    "termination": { "$ref": "#/$defs/termination" },
    "provenance": { "$ref": "#/$defs/provenance" }
  },
  "$defs": {
    "scenario_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "version", "source_sha256"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "role_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role_id", "name", "purpose"],
      "properties": {
        "role_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "authority": { "type": "object", "additionalProperties": true }
      }
    },
    "executor_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": ["executor_id", "type", "enabled"],
      "properties": {
        "executor_id": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "minLength": 1 },
        "adapter": { "type": "string" },
        "model": { "type": "string" },
        "timeout_seconds": { "type": "integer", "minimum": 1 },
        "command_template": {
          "type": "array",
          "items": { "type": "string" }
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enabled": { "type": "boolean" },
        "secret_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]*$"
          }
        }
      }
    },
    "participant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_id",
        "role_id",
        "role_snapshot",
        "executor_id",
        "executor_snapshot"
      ],
      "properties": {
        "participant_id": { "type": "string", "minLength": 1 },
        "role_id": { "type": "string", "minLength": 1 },
        "executor_id": { "type": "string", "minLength": 1 },
        "role_snapshot": { "$ref": "#/$defs/role_snapshot" },
        "executor_snapshot": { "$ref": "#/$defs/executor_snapshot" }
      }
    },
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage_id", "name", "actor_role_ids", "owner_gate"],
      "properties": {
        "stage_id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "actor_role_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "owner_gate": { "type": "boolean" }
      }
    },
    "termination": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_rounds": { "type": "integer", "minimum": 1 },
        "pause_every_rounds": { "type": "integer", "minimum": 1 }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bindings_sha256", "bindings_source", "generated_at"],
      "properties": {
        "bindings_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "bindings_source": { "type": "string", "minLength": 1 },
        "generated_at": { "type": "string", "minLength": 1 }
      }
    }
  }
}